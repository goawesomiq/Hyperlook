rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: photoshoots
    // Document ID: {photoshootId}
    // Fields:
    //   - userId: string (required)
    //   - createdAt: timestamp (required)
    //   - config: map (required)
    //   - results: list (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
       return isAuthenticated() && request.auth.token.phone_number == '+918888039433';
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function uidUnchanged() {
       return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
       return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'createdAt']) &&
             data.uid is string &&
             data.createdAt is timestamp;
    }

    function isValidPhotoshoot(data) {
      return hasRequiredFields(['userId', 'createdAt', 'config', 'results']) &&
             data.userId is string &&
             data.createdAt is timestamp &&
             data.config is map &&
             data.results is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      // Allow the Vercel server (using the REST API) to update credits, or the user to update their own profile
      allow update: if true; 
      allow delete: if isOwner(userId);
    }
    
    match /users/{userId}/generations/{docId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only backend admin writes these
    }

    match /photoshoots/{photoshootId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidPhotoshoot(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidPhotoshoot(request.resource.data) && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // Payments shouldn't be modifiable by users directly usually, or maybe they get updated by server? Allow admin
      allow delete: if false;
    }
  }
}
