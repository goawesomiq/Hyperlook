# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="your-gemini-api-key"

# REDIS_URL: Provided by Railway Redis plugin
REDIS_URL="redis://localhost:6379"

# FIREBASE_PROJECT_ID: Required for Firebase admin.
FIREBASE_PROJECT_ID="your-project-id"

# FIREBASE_PRIVATE_KEY: Required for Firebase admin.
FIREBASE_PRIVATE_KEY="your-private-key"

# FIREBASE_CLIENT_EMAIL: Required for Firebase admin.
FIREBASE_CLIENT_EMAIL="your-client-email"

# RAZORPAY_KEY_ID: Required for payments.
RAZORPAY_KEY_ID="rzp_test_mock"

# RAZORPAY_KEY_SECRET: Required for payments.
RAZORPAY_KEY_SECRET="mock_secret"
